{
    "name": "ai-public-grievance-system",
    "version": "1.0.0",
    "description": "Root package to manage all services",
    "scripts": {
        "start": "node index.js",
        "build": "npm install --prefix client && npm run build --prefix client && npm install",
        "install-all": "npm install --prefix client && npm install",
        "dev:server": "nodemon index.js",
        "dev:client": "npm run dev --prefix client",
        "dev": "concurrently \"npm run dev --prefix client\" \"nodemon index.js\""

    },
    "dependencies": {
        "axios": "^1.13.5",
        "bcryptjs": "^3.0.3",
        "concurrently": "^9.2.1",
        "cors": "^2.8.6",
        "dotenv": "^17.3.1",
        "express": "^5.2.1",
        "google-auth-library": "^10.6.1",
        "jsonwebtoken": "^9.0.3",
        "mongoose": "^9.2.2",
        "node-cron": "^4.2.1",
        "nodemon": "^3.1.14",
        "openai": "^6.34.0",
        "socket.io": "^4.8.3"
    }
}

